# Copy this file to .env and fill in real values.
# The app refuses to start unless all three are set to something other than
# these documented example values.

DASHBOARD_USER=changeme
DASHBOARD_PASS=change-this-to-a-strong-password
SECRET_KEY=change-this-to-a-long-random-string

# Optional, for OSINT threat scoring / Shodan lookups:
# ABUSEIPDB_KEY=
# SHODAN_KEY=

# Optional, tuning:
# SCAN_TIMEOUT=0.3
# SCAN_WORKERS=40
# NMAP_TIMEOUT=120
